SQL Query to select all columns of student table to get institute, block, district names 
SELECT `students`.*, `institute`.`inst_name`, `block`.`bname`, `district`.`dname`
FROM `students`
	, `institute`
	, `block` 
	LEFT JOIN `district` ON `block`.`d_id` = `district`.`d_id`;

-------------
AI query 
SELECT 
    s.name AS student_name,
    i.institute_name,
    b1.block_name AS student_block,
    d1.district_name AS student_district,
    b2.block_name AS exam_block,
    d2.district_name AS exam_district
FROM 
    student s
LEFT JOIN 
    institute i ON s.institute_id = i.id
LEFT JOIN 
    block b1 ON s.block_id = b1.id
LEFT JOIN 
    district d1 ON s.district_id = d1.id
LEFT JOIN 
    block b2 ON s.exam_block_id = b2.id
LEFT JOIN 
    district d2 ON s.exam_district_id = d2.id;

