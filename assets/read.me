---- Get District conditional 
// Database connection ($conn)
$state_id = $_GET['state_id'] ?? 0;
$exclude  = $_GET['exclude'] ?? 'false';

if ($exclude === 'true') {
    // QUERY A: Exclude districts present in Table 4
    $sql = "SELECT d.id, d.district_name 
            FROM district d
            LEFT JOIN table4 t4 ON d.id = t4.district_id
            WHERE d.state_id = ? 
            AND t4.district_id IS NULL";
} else {
    // QUERY B: Simple fetch for all districts in that state
    $sql = "SELECT id, district_name 
            FROM district 
            WHERE state_id = ?";
}

$stmt = $conn->prepare($sql);
$stmt->bind_param("i", $state_id);
$stmt->execute();
$result = $stmt->get_result();

$districts = [];
while ($row = $result->fetch_assoc()) {
    $districts[] = $row;
}

echo json_encode($districts);

